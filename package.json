{
  "name": "mdview",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "build:linux": "npm run tauri build",
    "build:windows": "npm run tauri build",
    "install:local": "npm run build:linux && bash scripts/install.sh",
    "install:windows": "npm run build:windows && powershell -ExecutionPolicy Bypass -File scripts/install.ps1",
    "update": "git pull && npm run install:local",
    "update:windows": "git pull && npm run install:windows",
    "set-version": "node scripts/set-version.cjs"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "@tauri-apps/plugin-opener": "^2",
    "highlight.js": "^11.11.1",
    "marked": "^18.0.0",
    "marked-highlight": "^2.2.4"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "typescript": "~5.6.2",
    "vite": "^6.0.3"
  }
}
